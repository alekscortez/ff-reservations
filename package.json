{
  "name": "ff-reservations",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @ff/web dev",
    "dev:mobile": "pnpm --filter @ff/mobile start",
    "build": "pnpm --filter @ff/web run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yaml,yml}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "typescript": "~5.9.2"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  }
}
