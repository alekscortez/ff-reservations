{
  "name": "ff-reservations",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:backend": "node --test 'backend/lambda/lib/*.test.mjs' 'backend/cognito-pre-token-gen/*.test.mjs' 'backend/cognito-customer-auth/*.test.mjs'",
    "test:all": "npm test -- --watch=false && npm run test:backend"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/cdk": "^21.2.10",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@ng-icons/core": "^33.2.2",
    "@ng-icons/lucide": "^33.2.2",
    "@spartan-ng/brain": "^0.0.1-alpha.690",
    "@tanstack/angular-table": "^8.21.4",
    "@zxing/browser": "^0.1.5",
    "angular-auth-oidc-client": "21.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.6.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.3",
    "@angular/cli": "^21.1.3",
    "@angular/compiler-cli": "^21.1.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1045.0",
    "@aws-sdk/client-secrets-manager": "^3.1045.0",
    "@aws-sdk/client-sns": "^3.1045.0",
    "@aws-sdk/lib-dynamodb": "^3.1045.0",
    "@spartan-ng/cli": "^0.0.1-alpha.690",
    "@types/qrcode": "^1.5.6",
    "autoprefixer": "^10.4.21",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
