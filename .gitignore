# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# Build outputs
**/dist
**/dist-ssr
**/build
**/coverage

# Node
**/node_modules
npm-debug.log
yarn-error.log
pnpm-debug.log

# Local env
**/.env
**/.env.local
**/.env.*.local

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
.history/*

# Miscellaneous
.sass-cache/
/connect.lock
/libpeerconnection.log
/typings

# System files
.DS_Store
Thumbs.db
/http-client/

# Backend lambda artifacts (the source itself IS tracked; build outputs are not)
backend/lambda/function.zip
backend/lambda/code_url.txt

# TypeScript incremental
**/*.tsbuildinfo

# Live-diff temp screenshots from chrome-devtools-mcp (keep .audit/.live-diff
# markdown notes; just exclude binary screenshots).
.tmp-*.png

# Unattended-session log (local only)
UNATTENDED_LOG.md
