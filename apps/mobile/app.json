{
  "expo": {
    "name": "Famoso Fuego",
    "slug": "ff-reservations",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "ffreservations",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.famosofuego.reservations"
    },
    "android": {
      "package": "com.famosofuego.reservations"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
